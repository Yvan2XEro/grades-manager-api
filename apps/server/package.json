{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"dev:pglite": "USE_PGLITE=true bun run --hot src/index.ts",
		"seed:scaffold": "bun run src/scripts/scaffold-seeds.ts",
		"seed": "bun run src/scripts/seed.ts",
		"seed:pglite": "USE_PGLITE=true bun run src/scripts/seed.ts",
		"seed:deliberation-test": "bun run src/scripts/seed-deliberation-test.ts",
		"seed:deliberation-test:pglite": "USE_PGLITE=true bun run src/scripts/seed-deliberation-test.ts",
		"start": "bun run dist/index.js",
		"db:push": "drizzle-kit push",
		"db:push:pglite": "USE_PGLITE=true drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:studio:pglite": "USE_PGLITE=true drizzle-kit studio",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.3.8",
		"@hono/trpc-server": "^0.4.0",
		"@trpc/client": "^11.5.0",
		"@trpc/server": "^11.5.0",
		"better-auth": "^1.3.9",
		"dotenv": "^17.2.1",
		"drizzle-orm": "^0.44.2",
		"handlebars": "^4.7.8",
		"hono": "^4.8.2",
		"json-rules-engine": "^7.3.1",
		"pg": "^8.14.1",
		"pg-boss": "^12.9.0",
		"puppeteer": "^24.32.1",
		"resend": "^6.9.2",
		"yaml": "^2.8.2",
		"zod": "^4.0.2"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@types/bun": "^1.2.6",
		"@types/pg": "^8.11.11",
		"drizzle-kit": "^0.31.2",
		"tsdown": "^0.14.1",
		"typescript": "^5.8.2"
	}
}
